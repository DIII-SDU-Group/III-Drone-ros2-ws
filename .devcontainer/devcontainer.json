{
	"name": "III-Drone Dev Container",
	"dockerComposeFile": [
        "docker-compose.yml",
        "../docker/docker-compose.colcon-build.yml"
    ],
	"service": "dev",
	"workspaceFolder": "/home/iii/ws",
    "shutdownAction": "stopCompose",

	"features": {
		"ghcr.io/devcontainers/features/docker-outside-of-docker:1": {
			"version": "latest",
			"enableNonRootDocker": "true",
			"moby": "false"
		}
	},

    "customizations": {
        "vscode": {
            "extensions":[
                "ms-vscode.cpptools",
                "ms-vscode.cpptools-themes",
                "twxs.cmake",
                "donjayamanne.python-extension-pack",
                "ms-iot.vscode-ros",
                "ms-azuretools.vscode-docker",
                "ms-python.python",
                "rioj7.command-variable",
                "augustocdias.tasks-shell-input",
                "ms-vscode.cpptools-extension-pack"
            ]
        }
    },

    "containerEnv": {
        "DISPLAY": "unix:0",
        "ROS_LOCALHOST_ONLY": "1",
        "ROS_DOMAIN_ID": "42"
    },

    "mounts": [
       "source=/tmp/.X11-unix,target=/tmp/.X11-unix,type=bind,consistency=cached",
        "source=/dev/dri,target=/dev/dri,type=bind,consistency=cached"
    ],

    "postCreateCommand": "./scripts/install_development_configuration.sh .config && bash -i -c \"rosdep update && rosdep install --from-paths src --ignore-src -y && sudo chown -R $(whoami) /home/iii/ws/ \"",
    // "postStartCommand": "bash -i -c \" colcon build --cmake-args -DCMAKE_BUILD_TYPE=Debug \" "
    // "postStartCommand": "./scripts/install_development_configuration.sh ${workspaceFolder}/.config"

}
