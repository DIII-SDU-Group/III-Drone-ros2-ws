{
	"name": "iii_drone",
	"dockerComposeFile": [
        "../docker-compose.yml",
        "../docker-compose.dev.yml"
    ],
	"service": "dev",
    "runServices": ["dev"],
	"workspaceFolder": "/home/iii/ws",
    "shutdownAction": "stopCompose",

	"features": {
		"ghcr.io/devcontainers/features/docker-outside-of-docker:1": {
			"version": "latest",
			"enableNonRootDocker": "true",
			"moby": "false"
		}
	},

    "customizations": {
        "vscode": {
            "extensions":[
                "ms-vscode.cpptools",
                "ms-vscode.cpptools-themes",
                "twxs.cmake",
                "donjayamanne.python-extension-pack",
                // "ms-iot.vscode-ros",
                "ms-azuretools.vscode-docker",
                "ms-python.python",
                "rioj7.command-variable",
                "augustocdias.tasks-shell-input",
                "ms-vscode.cpptools-extension-pack"
            ]
        }
    },

    "containerEnv": {
        // "DISPLAY": "unix:0",
        // "ROS_LOCALHOST_ONLY": "1",
        // "ROS_DOMAIN_ID": "42"
    },

    "mounts": [
       "source=/tmp/.X11-unix,target=/tmp/.X11-unix,type=bind,consistency=cached",
        "source=/dev/dri,target=/dev/dri,type=bind,consistency=cached"
    ],

    "initializeCommand": "./scripts/initialize.sh",
    // "onCreateCommand": "docker kill -d dev",
    "postCreateCommand": "scripts/post_create.sh",
    // "postStartCommand": "bash -i -c \" colcon build --cmake-argstops -DCMAKE_BUILD_TYPE=Debug \" "
    // "postStartCommand": "./scripts/install_development_configuration.sh ${workspaceFolder}/.config"

}
