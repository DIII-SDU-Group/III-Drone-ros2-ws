{
	"name": "iii_dev",
	"workspaceFolder": "/home/iii/ws",
    "remoteUser": "iii",
    "overrideCommand": false,

    "build": {
        "dockerfile": "../Dockerfile.dev",
        "context": "..",
        "args": {
            "ROS_DISTRO": "jazzy",
            "USERNAME": "iii",
            "USER_UID": "1000",
            "USER_GID": "1000"
        }
    },

    "customizations": {
        "vscode": {
            "extensions":[
                "ms-vscode.cpptools",
                "ms-vscode.cpptools-themes",
                "twxs.cmake",
                "donjayamanne.python-extension-pack",
                // "ms-iot.vscode-ros",
                "ms-azuretools.vscode-docker",
                "ms-python.python",
                "rioj7.command-variable",
                "augustocdias.tasks-shell-input",
                "ms-vscode.cpptools-extension-pack",
                "SumitNalavade.vscode-readme-editor"
            ]
        }
    },

    "containerEnv": {
        "ROS_DOMAIN_ID": "0",
        "DISPLAY": "${env:DISPLAY}",
        "QT_X11_NO_MITSHM": "1",
        "XAUTHORITY": "${env:XAUTHORITY}",
        "NVIDIA_VISIBLE_DEVICES": "all",
        "NVIDIA_DRIVER_CAPABILITIES": "all",
        "__GLX_VENDOR_LIBRARY_NAME": "nvidia"
    },

    "mounts": [
       "source=/tmp/.X11-unix,target=/tmp/.X11-unix,type=bind,consistency=cached",
        "source=.,target=/home/iii/ws,type=bind,consistency=cached",
        // "source=/run/user/1000/at-spi/bus_1,target=/run/user/1000/at-spi/bus_1,type=bind",
        "source=${env:XAUTHORITY},target=${env:XAUTHORITY},type=bind",
    ],

    "runArgs": [
        "--cap-add", "SYS_ADMIN",
        "--cap-add", "SYS_PTRACE",
        "--device", "/dev/fuse",
        "--security-opt", "apparmor:unconfined",
        "--ipc","host",
        "--network","host",
        "--gpus", "all",
        "--cgroupns", "host",
        "--tmpfs", "/run",
        "--tmpfs", "/run/lock",
        "-v", "/sys/fs/cgroup:/sys/fs/cgroup:rw"
    ],
    "initializeCommand": "ls",
    "postCreateCommand": ".devcontainer/post_create.sh",
    "postStartCommand": ".devcontainer/post_start.sh",

}
