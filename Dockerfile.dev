ARG ROS_DISTRO=jazzy
ARG USERNAME=iii
ARG USER_UID=1000
ARG USER_GID=1000

FROM osrf/ros:${ROS_DISTRO}-desktop-full

ARG USERNAME
ARG USER_UID
ARG USER_GID

# Required on Ubuntu 24+/PEP668 images so pip can install project dependencies.
ENV PIP_BREAK_SYSTEM_PACKAGES=1

# Make transient Ubuntu mirror failures less likely to abort long image builds.
RUN printf '%s\n' \
    'Acquire::Retries "5";' \
    'Acquire::http::Timeout "30";' \
    'Acquire::https::Timeout "30";' \
    'Acquire::http::Pipeline-Depth "0";' \
    > /etc/apt/apt.conf.d/80-iii-network

# This network blocks Ubuntu HTTP mirrors on port 80. Use HTTPS for Ubuntu
# archive/security sources, but leave ROS sources on HTTP because packages.ros.org
# does not present a certificate valid for that host.
RUN set -eux; \
    for file in /etc/apt/sources.list /etc/apt/sources.list.d/*.list /etc/apt/sources.list.d/*.sources; do \
        [ -f "${file}" ] || continue; \
        sed -i -E \
            -e 's|http://([A-Za-z0-9.-]*archive\.ubuntu\.com/ubuntu)|https://\1|g' \
            -e 's|http://(security\.ubuntu\.com/ubuntu)|https://\1|g' \
            "${file}"; \
    done

# Create or rename user/group to match requested identity.
RUN set -eux; \
    existing_group="$(getent group "${USER_GID}" | cut -d: -f1 || true)"; \
    if [ -z "${existing_group}" ]; then \
        groupadd --gid "${USER_GID}" "${USERNAME}"; \
    elif [ "${existing_group}" != "${USERNAME}" ]; then \
        groupmod -n "${USERNAME}" "${existing_group}"; \
    fi; \
    existing_user="$(getent passwd "${USER_UID}" | cut -d: -f1 || true)"; \
    if [ -z "${existing_user}" ]; then \
        if id -u "${USERNAME}" >/dev/null 2>&1; then \
            usermod --uid "${USER_UID}" --gid "${USER_GID}" "${USERNAME}"; \
        else \
            useradd --uid "${USER_UID}" --gid "${USER_GID}" -m "${USERNAME}"; \
        fi; \
    elif [ "${existing_user}" != "${USERNAME}" ]; then \
        usermod -l "${USERNAME}" -d "/home/${USERNAME}" -m "${existing_user}"; \
        usermod --uid "${USER_UID}" --gid "${USER_GID}" "${USERNAME}"; \
    else \
        usermod --uid "${USER_UID}" --gid "${USER_GID}" "${USERNAME}"; \
    fi; \
    mkdir -p "/home/${USERNAME}"; \
    chown -R "${USER_UID}:${USER_GID}" "/home/${USERNAME}"

# Install stable apt dependencies in one layer. Avoid full apt upgrades: the
# base image pins the OS/ROS baseline, while upgrades are slow and
# non-reproducible. Keep GUI/simulation-only dependencies in a later layer.
RUN apt-get update && apt-get install -y --no-install-recommends \
    sudo \
    ca-certificates \
    locales \
    wget \
    ros-${ROS_DISTRO}-rmw-cyclonedds-cpp \
    ros-${ROS_DISTRO}-generate-parameter-library \
    ros-${ROS_DISTRO}-generate-parameter-library-py \
    ros-${ROS_DISTRO}-parameter-traits \
    python3-colcon-common-extensions \
    python3-pip \
    ccache \
    ninja-build \
    vim \
    git \
    lsb-release \
    tmux \
    htop \
    gdb \
    build-essential \
    cmake && \
    (apt-get purge -y modemmanager || true) && \
    rm -rf /var/lib/apt/lists/*
RUN echo "${USERNAME} ALL=(root) NOPASSWD:ALL" > "/etc/sudoers.d/${USERNAME}" && \
    chmod 0440 "/etc/sudoers.d/${USERNAME}" && \
    usermod -s /bin/bash "${USERNAME}" && \
    usermod -a -G dialout "${USERNAME}" && \
    rm -rf /var/lib/apt/lists/*

# Copy the entrypoint script
COPY entrypoint_dev.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh

# Create workspace folder and set ownership
RUN mkdir -p "/home/${USERNAME}/ws"
RUN chown -R "${USERNAME}:${USERNAME}" "/home/${USERNAME}/ws"

WORKDIR /home/${USERNAME}/ws

# Set the entrypoint
ENTRYPOINT ["/entrypoint.sh"]

RUN echo "source /opt/ros/${ROS_DISTRO}/setup.bash" >> /etc/bash.bashrc
RUN echo "source /home/${USERNAME}/ws/install/setup.bash" >> /etc/bash.bashrc

USER ${USERNAME}

COPY requirements.txt /requirements.txt

RUN sudo chown -R "${USERNAME}:${USERNAME}" /requirements.txt

RUN pip3 install --upgrade pip
RUN pip3 install -r /requirements.txt

RUN sudo rm -rf /requirements.txt

RUN wget https://github.com/mavlink/qgroundcontrol/releases/download/v5.0.8/QGroundControl-x86_64.AppImage -P "/home/${USERNAME}" -O "/home/${USERNAME}/QGroundControl.AppImage"
RUN chmod +x "/home/${USERNAME}/QGroundControl.AppImage"

# Install development tools
COPY tools/terminator /home/${USERNAME}/.config/terminator
COPY tools/QGroundControl.org /home/${USERNAME}/.config/QGroundControl.org

RUN sudo chown -R "${USERNAME}:${USERNAME}" "/home/${USERNAME}/.config"

# Update bashrc
COPY .bashrc /home/${USERNAME}/.bashrc
RUN sudo chown "${USERNAME}:${USERNAME}" "/home/${USERNAME}/.bashrc"

USER root

# GUI/simulation operator tools. Keep this after Python and QGC layers so
# transient Ubuntu mirror failures do not invalidate the stable base layer.
RUN apt-get update && apt-get install -y --no-install-recommends \
    fuse \
    gstreamer1.0-plugins-bad \
    gstreamer1.0-plugins-good \
    gstreamer1.0-libav \
    gstreamer1.0-gl \
    libfuse2 \
    libgstreamer1.0-dev \
    libgstreamer-plugins-base1.0-dev \
    libxcb-xinerama0 \
    libxkbcommon-x11-0 \
    libxcb-cursor0 \
    terminator && \
    rm -rf /var/lib/apt/lists/*

# Workspace runtime/build dependencies. Keep this late so adding package
# dependencies does not invalidate the stable tooling, Python, or QGC layers.
RUN apt-get update && apt-get install -y --no-install-recommends \
    ros-${ROS_DISTRO}-pcl-ros \
    libopencv-dev \
    python3-opencv \
    ros-${ROS_DISTRO}-cv-bridge \
    ros-${ROS_DISTRO}-image-transport \
    ros-${ROS_DISTRO}-usb-cam \
    libzmq3-dev && \
    rm -rf /var/lib/apt/lists/*

ENV SHELL=/bin/bash
ENV container=docker
STOPSIGNAL SIGRTMIN+3
CMD ["/sbin/init"]
