{
    "version": "0.2.0",
    "configurations": [
        // Configurations for the following nodes:
        // iii_drone_core/hough_transformer
        // iii_drone_core/pl_dir_computer
        // iii_drone_core/pl_mapper
        // iii_drone_core/trajectory_generator
        // iii_drone_core/maneuver_controller
        // iii_drone_mission/mission_executor
        {
            "name": "hough_transformer",
            "type": "cppdbg",
            "request": "attach",
            "program": "${workspaceFolder}/install/iii_drone_core/lib/iii_drone_core/hough_transformer",
            "processId": "${command:pickProcess}",
            "MIMode": "gdb",
            "miDebuggerPath": "/usr/bin/gdb",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ]
        },
