{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Install development configuration",
            "type": "shell",
            "command": "${workspaceFolder}/src/III-Drone-Configuration/scripts/install.sh",
            "args": [
                "${workspaceFolder}/.config"
            ],
            "problemMatcher": []
        },
        {
            "label": "PX4 clean",
            "type": "shell",
            "command": "if [ ${input:cleanPrompt} == \"Yes\" ]; then cd ~/ws/PX4-Autopilot && make clean; else echo \"Cleaning cancelled.\"; exit 1; fi",
            "group": {
                "kind": "build"
            }
        },
        {
            "label": "PX4 build firmware",
            "type": "shell",
            "command": "cd ~/ws/PX4-Autopilot && make px4_fmu-v6x_default",
            "group": {
                "kind": "build"
            }
        },
        {
            "label": "ROS2 clean",
            "type": "shell",
            "command": "if [ ${input:cleanPrompt} == \"Yes\" ]; then rm -rf build install log; else echo \"Cleaning cancelled.\"; exit 1; fi",
            "group": {
                "kind": "build"
            }
        },
        {
            "label": "ROS2 full build",
            "type": "shell",
            "command": "COLCON_HOME=/home/iii/ws colcon build --symlink-install --cmake-args -DCMAKE_BUILD_TYPE=Debug -DCMAKE_EXPORT_COMPILE_COMMANDS=ON",
            "group": {
                "kind": "build"
            }
        },
        {
            "label": "ROS2 clean build",
            "type": "shell",
            "dependsOn": [
                "ROS2 clean",
                "ROS2 full build"
            ],
            "dependsOrder": "sequence",
            "group": {
                "kind": "build"
            }
        },
        {
            "label": "ROS2 build package",
            "type": "shell",
            "command": "COLCON_HOME=/home/iii/ws colcon build --packages-select ${input:buildPackage} --symlink-install --cmake-args -DCMAKE_BUILD_TYPE=Debug -DCMAKE_EXPORT_COMPILE_COMMANDS=ON",
            "group": {
                "kind": "build"
            }
        },
        {
            "label": "ROS2 build packages up to",
            "type": "shell",
            "command": "COLCON_HOME=/home/iii/ws colcon build --packages-up-to ${input:buildPackage} --symlink-install --cmake-args -DCMAKE_BUILD_TYPE=Debug -DCMAKE_EXPORT_COMPILE_COMMANDS=ON",
            "group": {
                "kind": "build"
            }
        },
        {
            "label": "ROS2 build III packages",
            "type": "shell",
            "command": "COLCON_HOME=/home/iii/ws colcon build --packages-select-regex iii_drone_* --symlink-install --cmake-args -DCMAKE_BUILD_TYPE=Debug -DCMAKE_EXPORT_COMPILE_COMMANDS=ON",
            "group": {
                "kind": "build"
            }
        },
        {
            "label": "ROS2 build with colcon args",
            "type": "shell",
            "command": "COLCON_HOME=/home/iii/ws colcon build ${input:promptColconArgs} --symlink-install --cmake-args -DCMAKE_BUILD_TYPE=Debug -DCMAKE_EXPORT_COMPILE_COMMANDS=ON",
            "group": {
                "kind": "build"
            }
        },
        {
            "label": "Launch ROS2 III system",
            "type": "shell",
            "command": "terminator --no-dbus -x bash -lc 'source ${workspaceFolder}/setup/setup_dev.bash && iii system boot --attach'",
            "group": {
                "kind": "test"
            }
        },
        {
            "label": "Launch simulation environment",
            "type": "shell",
            "command": "terminator --no-dbus -x bash -lc '${workspaceFolder}/tools/simulation/launch_simulation_tools.sh --recreate'",
            "group": {
                "kind": "test"
            }
        },
        {
            "label": "Launch Terminator",
            "type": "shell",
            "command": "terminator --no-dbus",
            "group": {
                "kind": "test"
            }
        }
    ],
    "inputs": [
        {
            "id": "dockerComposeBuildFiles",
            "type": "command",
            "command": "extension.commandvariable.file.pickFile",
            "description": "Select the docker-compose files to build",
            "fromWorkspace": "${workspaceFolderBasename}",
            "args": {
                "include": "docker/docker-compose*.yml",
            }
        },
        {
            "id": "cleanPrompt",
            "description": "Are you sure you want to clean the workspace?",
            "type": "pickString",
            "options": [
                "No",
                "Yes"
            ],
            "default": "No"
        },
        {
            "id": "buildPackage",
            "type": "command",
            "command": "shellCommand.execute",
            "args": {
                "description": "Select the package to build",
                "command": "${workspaceFolder}/.vscode/get_iii_drone_package_names.sh",
                "taskId": "ros2BuildPackageShellCommandLastSelection",
                "rememberPrevious": true
            }
        },
        {
            "id": "promptColconArgs",
            "type": "command",
            "command": "extension.commandvariable.promptStringRemember",
            "args": {
                "description": "Enter additional colcon arguments",
                "key": "args",
            }
        },
        {
            "id": "runPackage",
            "type": "command",
            "command": "shellCommand.execute",
            "args": {
                "description": "Select the package",
                "command": "${workspaceFolder}/.vscode/get_iii_drone_package_names.sh",
                "taskId": "ros2RunPackageShellCommandLastSelection",
                "rememberPrevious": true
            }
        },
        {
            "id": "runExecutable",
            "type": "command",
            "command": "shellCommand.execute",
            "args": {
                "description": "Select the executable",
                "command": "${workspaceFolder}/.vscode/get_package_executable_names.sh ${input:runPackage}",
                "fieldSeparator": "\n",
                "taskId": "ros2RunExecutableShellCommandLastSelection",
                "rememberPrevious": true
            }
        },
        {
            "id": "runROS2Args",
            "description": "ROS2 arguments",
            "type": "command",
            "command": "extension.commandvariable.promptStringRemember",
            "args": {
                "description": "Enter the ROS2 arguments to pass to the node",
                "key": "args",
            }
        },       
    ]
}
